import { expect, toBe, test, suite, run } from "std/test"
import { toString } from "std/string"
import { json, text, redirect, notFound, badRequest, parseBody, pathMatch } from "std/http"

val s = suite("std/http", [
  test("json helper sets status and content-type", () =>
    val resp = json(200, { "ok": true })
    val r = [expect(resp["status"]).toBe(200), expect(resp["headers"]["Content-Type"]).toBe("application/json")]
    r
  ),

  test("text helper sets status and body", () =>
    val resp = text(200, "hello world")
    val r = [expect(resp["status"]).toBe(200), expect(resp["body"]).toBe("hello world")]
    r
  ),

  test("redirect sets 302 and Location header", () =>
    val resp = redirect("/home")
    val r = [expect(resp["status"]).toBe(302), expect(resp["headers"]["Location"]).toBe("/home")]
    r
  ),

  test("notFound has status 404", () => [
    expect(notFound["status"]).toBe(404)
  ]),

  test("badRequest has status 400", () =>
    val resp = badRequest("missing field")
    val r = [expect(resp["status"]).toBe(400)]
    r
  ),

  test("parseBody parses JSON body", () =>
    val req = { "method": "POST", "path": "/", "query": "", "headers": {}, "body": "{\"x\": 99}" }
    val body = parseBody(req)
    val r = [expect(body["x"]).toBe(99)]
    r
  ),

  test("pathMatch extracts named segments", () =>
    val m = pathMatch("/users/:id/posts/:postId", "/users/42/posts/7")
    val r = [expect(m["id"]).toBe("42"), expect(m["postId"]).toBe("7")]
    r
  ),

  test("pathMatch returns null on mismatch", () =>
    val m = pathMatch("/users/:id", "/products/5")
    val r = [expect(m).toBe(null)]
    r
  ),
])

run(s)
