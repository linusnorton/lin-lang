import { expect, toBe, toSucceed, toFail, test, suite, run } from "std/test"
import { toString } from "std/string"
import { length } from "std/array"
import { readFile, writeFile, appendFile, readLines, readJson, writeJson, exists, isFile, isDir, stat, ls, mkdir, rm, cp, mv, readFileBytes, writeFileBytes, writeLines } from "std/fs"

val tmpRead   = "/tmp/lin_test_fs_read.txt"
val tmpExists = "/tmp/lin_test_fs_exists.txt"
val tmpAppend = "/tmp/lin_test_fs_append.txt"
val tmpJson   = "/tmp/lin_test_fs_json.json"
val tmpStat   = "/tmp/lin_test_fs_stat.txt"
val tmpDir    = "/tmp/lin_test_fs_dir"
val tmpRename = "/tmp/lin_test_fs_rename_src.txt"
val tmpRenameDst = "/tmp/lin_test_fs_rename_dst.txt"

val s = suite("std/fs", [
  test("writeFile then readFile round-trips", () =>
    writeFile(tmpRead, "hello lin")
    val content = readFile(tmpRead)
    val checks = [
      expect(content).toBe("hello lin")
    ]
    checks
  ),

  test("readFile missing path returns error", () =>
    val result = readFile("/nonexistent/path/does/not/exist.txt")
    val checks = [
      expect(result["type"]).toBe("error")
    ]
    checks
  ),

  test("exists false before write, true after", () =>
    rm(tmpExists, {})
    val before = exists(tmpExists)
    writeFile(tmpExists, "x")
    val after = exists(tmpExists)
    val r = [expect(before).toBe(false), expect(after).toBe(true)]
    r
  ),

  test("appendFile accumulates content", () =>
    writeFile(tmpAppend, "line1\n")
    appendFile(tmpAppend, "line2\n")
    val content = readFile(tmpAppend)
    val checks = [
      expect(content).toBe("line1\nline2\n")
    ]
    checks
  ),

  test("readLines splits on newlines", () =>
    writeFile(tmpRead, "alpha\nbeta\ngamma")
    val lines = readLines(tmpRead)
    val checks = [
      expect(length(lines)).toBe(3)
    ]
    checks
  ),

  test("readLines returns error for missing file", () =>
    val result = readLines("/nonexistent/path/that/does/not/exist.txt")
    val checks = [
      expect(result["type"]).toBe("error")
    ]
    checks
  ),

  test("writeJson then readJson round-trips", () =>
    val data = { "name": "lin", "version": 1 }
    writeJson(tmpJson, data, {})
    val loaded = readJson(tmpJson)
    val checks = [
      expect(loaded["name"]).toBe("lin")
    ]
    checks
  ),

  test("writeJson default is pretty (multiline)", () =>
    val data = { "name": "lin" }
    writeJson(tmpJson, data, {})
    val content = readFile(tmpJson)
    val checks = [
      expect(isFile(tmpJson)).toBe(true)
    ]
    checks
  ),

  test("writeJson compact option writes compact JSON", () =>
    val data = { "name": "lin", "version": 1 }
    writeJson(tmpJson, data, { "compact": true })
    val content = readFile(tmpJson)
    val checks = [
      expect(content).toBe("{\"name\":\"lin\",\"version\":1}")
    ]
    checks
  ),

  test("isFile false before write, true after", () =>
    val tmpIsFile = "/tmp/lin_test_fs_isfile.txt"
    rm(tmpIsFile, {})
    val before = isFile(tmpIsFile)
    writeFile(tmpIsFile, "hello")
    val after = isFile(tmpIsFile)
    val r = [expect(before).toBe(false), expect(after).toBe(true)]
    r
  ),

  test("isDir returns true for temp dir, false for file", () =>
    writeFile(tmpRead, "x")
    val r = [expect(isDir("/tmp")).toBe(true), expect(isDir(tmpRead)).toBe(false)]
    r
  ),

  test("stat returns metadata for existing file", () =>
    writeFile(tmpStat, "hello lin")
    val s = stat(tmpStat)
    val r = [expect(s["size"]).toBe(9), expect(s["isFile"]).toBe(true), expect(s["isDir"]).toBe(false)]
    r
  ),

  test("stat returns error for missing path", () =>
    val s = stat("/nonexistent/path/that/does/not/exist.txt")
    val checks = [
      expect(s["type"]).toBe("error")
    ]
    checks
  ),

  test("stat includes mode field", () =>
    writeFile(tmpStat, "hello")
    val s = stat(tmpStat)
    val mode = s["mode"]
    val checks = [
      expect(mode != null).toBe(true)
    ]
    checks
  ),

  test("mkdir creates directory", () =>
    val mkdirPath = "/tmp/lin_test_fs_mkdir_once"
    mkdir(mkdirPath, {})
    val checks = [
      expect(isDir(mkdirPath)).toBe(true)
    ]
    checks
  ),

  test("mkdir with parents option creates nested directories", () =>
    val nested = "/tmp/lin_test_fs_mkdirall/a/b"
    mkdir(nested, { "parents": true })
    val checks = [
      expect(isDir(nested)).toBe(true)
    ]
    checks
  ),

  test("ls returns entries in a directory", () =>
    val listTmpDir = "/tmp/lin_test_fs_listdir"
    mkdir(listTmpDir, { "parents": true })
    writeFile("/tmp/lin_test_fs_listdir/x.txt", "x")
    writeFile("/tmp/lin_test_fs_listdir/y.txt", "y")
    val entries = ls(listTmpDir, {})
    val checks = [
      expect(length(entries)).toBe(2)
    ]
    checks
  ),

  test("ls returns error for missing directory", () =>
    val result = ls("/nonexistent/path/that/does/not/exist", {})
    val checks = [
      expect(result["type"]).toBe("error")
    ]
    checks
  ),

  test("ls with recursive option returns nested entries", () =>
    val recDir = "/tmp/lin_test_fs_ls_recursive"
    mkdir(recDir, { "parents": true })
    mkdir("/tmp/lin_test_fs_ls_recursive/sub", { "parents": true })
    writeFile("/tmp/lin_test_fs_ls_recursive/a.txt", "a")
    writeFile("/tmp/lin_test_fs_ls_recursive/sub/b.txt", "b")
    val entries = ls(recDir, { "recursive": true })
    val checks = [
      expect(length(entries) >= 3).toBe(true)
    ]
    checks
  ),

  test("rm removes a file", () =>
    writeFile(tmpRename, "to delete")
    val before = exists(tmpRename)
    rm(tmpRename, {})
    val after = exists(tmpRename)
    val r = [expect(before).toBe(true), expect(after).toBe(false)]
    r
  ),

  test("rm returns error for missing file", () =>
    val result = rm("/nonexistent/path/that/does/not/exist.txt", {})
    val checks = [
      expect(result["type"]).toBe("error")
    ]
    checks
  ),

  test("rm with recursive option removes directory", () =>
    val rmDir = "/tmp/lin_test_fs_rm_recursive"
    mkdir(rmDir, { "parents": true })
    writeFile("/tmp/lin_test_fs_rm_recursive/file.txt", "x")
    rm(rmDir, { "recursive": true })
    val checks = [
      expect(exists(rmDir)).toBe(false)
    ]
    checks
  ),

  test("mv moves a file", () =>
    writeFile(tmpRename, "hello rename")
    mv(tmpRename, tmpRenameDst)
    val r = [expect(exists(tmpRename)).toBe(false), expect(exists(tmpRenameDst)).toBe(true), expect(readFile(tmpRenameDst)).toBe("hello rename")]
    r
  ),

  test("cp copies a file", () =>
    val cpSrc = "/tmp/lin_test_fs_cp_src.txt"
    val cpDst = "/tmp/lin_test_fs_cp_dst.txt"
    writeFile(cpSrc, "copy me")
    rm(cpDst, {})
    cp(cpSrc, cpDst)
    val r = [expect(exists(cpSrc)).toBe(true), expect(exists(cpDst)).toBe(true), expect(readFile(cpDst)).toBe("copy me")]
    r
  ),

  test("readFileBytes and writeFileBytes round-trip", () =>
    val byteFile = "/tmp/lin_test_fs_bytes.bin"
    // readFileBytes returns a packed UInt8[] byte buffer (§35.1).
    val bytesIn = readFileBytes(tmpRead)
    writeFileBytes(byteFile, bytesIn)
    val bytesOut = readFileBytes(byteFile)
    val checks = [
      expect(length(bytesIn)).toBe(length(bytesOut)),
      expect(bytesIn[0]).toBe(bytesOut[0])
    ]
    checks
  ),

  test("writeLines and readLines round-trip", () =>
    val linesFile = "/tmp/lin_test_fs_lines_rt.txt"
    writeLines(linesFile, ["foo", "bar", "baz"])
    val result = readLines(linesFile)
    val checks = [
      expect(length(result)).toBe(3)
    ]
    checks
  ),
])

run(s)
