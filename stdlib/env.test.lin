import { expect, toBe, test, suite, run } from "std/test"
import { getEnv, setEnv, unsetEnv, environ } from "std/env"

val s = suite("std/env", [
  test("setEnv then getEnv round-trips", () =>
    setEnv("LIN_TEST_VAR", "hello")
    val result = getEnv("LIN_TEST_VAR")
    val checks = [
      expect(result).toBe("hello")
    ]
    checks
  ),

  test("getEnv returns null for nonexistent variable", () =>
    val result = getEnv("LIN_NONEXISTENT_VAR_XYZ_12345")
    val checks = [
      expect(result).toBe(null)
    ]
    checks
  ),

  test("unsetEnv removes variable", () =>
    setEnv("LIN_TEST_UNSET_VAR", "temporary")
    unsetEnv("LIN_TEST_UNSET_VAR")
    val result = getEnv("LIN_TEST_UNSET_VAR")
    val checks = [
      expect(result).toBe(null)
    ]
    checks
  ),

  test("environ returns an object with string values", () =>
    setEnv("LIN_TEST_ENVIRON_VAR", "env_value")
    val env = environ()
    val checks = [
      expect(env["LIN_TEST_ENVIRON_VAR"]).toBe("env_value")
    ]
    checks
  ),

  test("setEnv overwrites existing variable", () =>
    setEnv("LIN_TEST_OVERWRITE", "first")
    setEnv("LIN_TEST_OVERWRITE", "second")
    val result = getEnv("LIN_TEST_OVERWRITE")
    val checks = [
      expect(result).toBe("second")
    ]
    checks
  ),
])

run(s)
