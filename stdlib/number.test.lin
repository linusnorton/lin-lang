import { expect, toBe, test, suite, run } from "std/test"
import { parseInt32, parseFloat64, toInt32, toFloat64, toFloat32, isInt32, isFloat64, tryParseInt32, tryParseFloat64 } from "std/number"
import { f32ToBe } from "std/bytes"
import { length } from "std/array"

val s = suite("std/number", [
  test("parseInt32 parses integer string", () => [
    expect(parseInt32("42")).toBe(42)
  ]),

  test("parseFloat64 parses float string", () => [
    expect(parseFloat64("3.14")).toBe(3.14)
  ]),

  test("toInt32 truncates float", () => [
    expect(toInt32(3.9)).toBe(3)
  ]),

  test("toFloat64 converts int to float", () => [
    expect(toFloat64(5)).toBe(5.0)
  ]),

  test("toFloat32 narrows Float64 to a Float32 usable by f32ToBe", () => [
    // The only way to get a Float32 from a computed Float64. 0.5 is exact in f32:
    // big-endian bytes are 0x3F000000.
    expect(length(f32ToBe(toFloat32(0.5)))).toBe(4),
    expect(f32ToBe(toFloat32(0.5))[0]).toBe(63),
    expect(f32ToBe(toFloat32(0.5))[1]).toBe(0)
  ]),

  test("isInt32 true for integer string", () => [
    expect(isInt32("42")).toBe(true)
  ]),

  test("isInt32 false for float string", () => [
    expect(isInt32("3.14")).toBe(false)
  ]),

  test("isInt32 false for non-numeric string", () => [
    expect(isInt32("abc")).toBe(false)
  ]),

  test("isFloat64 true for float string", () => [
    expect(isFloat64("3.14")).toBe(true)
  ]),

  test("isFloat64 true for integer string", () => [
    expect(isFloat64("42")).toBe(true)
  ]),

  test("isFloat64 false for non-numeric string", () => [
    expect(isFloat64("abc")).toBe(false)
  ]),

  test("tryParseInt32 returns int for valid string", () => [
    expect(tryParseInt32("42")).toBe(42)
  ]),

  test("tryParseInt32 returns null for invalid string", () => [
    expect(tryParseInt32("abc")).toBe(null)
  ]),

  test("tryParseFloat64 returns float for valid string", () => [
    expect(tryParseFloat64("3.14")).toBe(3.14)
  ]),

  test("tryParseFloat64 returns null for invalid string", () => [
    expect(tryParseFloat64("abc")).toBe(null)
  ]),

  test("dot-syntax for number parsing", () =>
    [
      expect("99".parseInt32()).toBe(99),
      expect("2.5".parseFloat64()).toBe(2.5),
      expect("7".isInt32()).toBe(true)
    ]
  ),
])

run(s)
