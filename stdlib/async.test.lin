import { expect, toBe, test, suite, run } from "std/test"
import { toString } from "std/string"
import { async, await, parallel, worker, request, close } from "std/async"

val s = suite("std/async", [
  test("async/await basic value", () =>
    val p = async(() => 42)
    val result = await(p)
    expect(result).toBe(42)
  ),

  test("async captures val binding", () =>
    val x = 10
    val p = async(() => x * 3)
    expect(await(p)).toBe(30)
  ),

  test("parallel runs all tasks", () =>
    val results = parallel([() => 1, () => 2, () => 3])
    expect(toString(results)).toBe("[1, 2, 3]")
  ),

  test("worker request/reply", () =>
    val w = worker(msg => msg * 2, () => null)
    val reply = request(w, 21)
    close(w)
    expect(reply).toBe(42)
  ),

  test("async captures string val (deep-copied across thread)", () =>
    val name = "world"
    val p = async(() => "hello ${name}")
    expect(await(p)).toBe("hello world")
  ),

  test("async captures array val", () =>
    val xs = [10, 20, 30]
    val p = async(() => xs[1])
    expect(await(p)).toBe(20)
  ),

  test("fault in thunk is caught as Error at await (div by zero)", () =>
    val z = 0
    val p = async(() => 42 / z)
    val r = await(p)
    // The fault surfaces as an Error object { type: "error", message: ... };
    // the program continues rather than aborting (spec §32.2.2).
    expect(r["type"]).toBe("error")
  ),

  test("fault in thunk: array out of bounds caught as Error", () =>
    val arr = [1, 2, 3]
    val p = async(() => arr[99])
    val r = await(p)
    expect(r["type"]).toBe("error")
  ),

  test("program continues after a caught async fault", () =>
    val z = 0
    val bad = await(async(() => 1 / z))
    val good = await(async(() => 7 + 1))
    expect(good).toBe(8)
  ),
])

run(s)
