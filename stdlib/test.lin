import { print } from "std/io"

val _pass = { "type": "pass" }

val _fail = (message: String): Json =>
  { "type": "fail", "message": message }

val _runTest = (t: Json): Json =>
  val results = t["run"]()
  val assertions = if results is Json[]
    then results
    else [results]
  val failures = assertions.filter(a => a["type"] == "fail")
  if length(failures) == 0
    then { "type": "pass", "name": t["name"] }
    else { "type": "fail", "name": t["name"], "failures": failures }

val _printSuiteResults = (suiteResult: Json): Null =>
  print(suiteResult["name"])
  suiteResult["results"].for(r =>
    if r["type"] == "pass"
      then print("  ok  ${r["name"]}")
      else
        print("  FAIL  ${r["name"]}")
        r["failures"].for(f => print("    ${f["message"]}"))
  )

// An Asserter is { "value": Json } — assertion methods take it as first arg via dot-syntax.

export val expect = (value: Json): Json =>
  { "value": value }

export val toBe = (asserter: Json, expected: Json): Json =>
  val value = asserter["value"]
  if value == expected
    then _pass
    else _fail("expected: ${toString(expected)}\n    actual:   ${toString(value)}")

export val toBeNull = (asserter: Json): Json =>
  val value = asserter["value"]
  if value == null
    then _pass
    else _fail("expected null, got: ${toString(value)}")

export val toSatisfy = (asserter: Json, pred: Function): Json =>
  val value = asserter["value"]
  if pred(value)
    then _pass
    else _fail("value did not satisfy predicate: ${toString(value)}")

export val toSucceed = (asserter: Json): Json =>
  val value = asserter["value"]
  if value["type"] == "success"
    then _pass
    else _fail("expected success, got: ${toString(value)}")

export val toFail = (asserter: Json): Json =>
  val value = asserter["value"]
  if value["type"] == "failure"
    then _pass
    else _fail("expected failure, got: ${toString(value)}")

export val toFailWith = (asserter: Json, message: String): Json =>
  val value = asserter["value"]
  if value["type"] == "failure" && value["error"] == message
    then _pass
    else _fail("expected failure with \"${message}\", got: ${toString(value)}")

export val test = (name: String, body: Function): Json =>
  { "name": name, "run": body }

export val suite = (name: String, tests: Json[]): Json =>
  { "name": name, "tests": tests }

export val run = (s: Json): Null =>
  val results = s["tests"].map(t => _runTest(t))
  val failed = results.filter(r => r["type"] == "fail")
  val passCount = length(results) - length(failed)
  val failCount = length(failed)
  _printSuiteResults({ "name": s["name"], "results": results })
  if failCount == 0
    then print("${toString(passCount)} passed")
    else
      print("${toString(failCount)} failed, ${toString(passCount)} passed")
      __exit(1)
