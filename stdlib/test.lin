import { print } from "std/io"
import { toString } from "std/string"
import { filter, length, for, map } from "std/array"
import { exit } from "std/io"

// An Assertion is the result of a single matcher: a pass, or a fail carrying a message.
// Matchers return this CONCRETE type (not Json) on purpose: it makes a test body's type
// `Assertion[]`, so the checker forces every test to return an ARRAY of assertions. A bare
// single assertion or a stray non-assertion body value is then a COMPILE error, which is what
// guarantees that every `expect(...)` in a multi-assertion test is actually evaluated. See the
// array-of-assertions test form documented in docs/STDLIB.md.
type Assertion = { "type": String }

val _pass = (): Assertion =>
  { "type": "pass" }

val _fail = (message: String): Assertion =>
  { "type": "fail", "message": message }

val _evalResult = (name: String, results: Assertion[]): Json =>
  val failures = results.filter(a => a["type"] == "fail")
  if length(failures) == 0 then { "type": "pass", "name": name }
  else { "type": "fail", "name": name, "failures": failures }

val _printFail = (r: Json): Null =>
  print("  FAIL  ${r["name"]}")
  r["failures"].for(f => print("    ${f["message"]}"))

val _printSuiteResults = (suiteResult: Json): Null =>
  print(suiteResult["name"])
  suiteResult["results"].for(r =>
    if r["type"] == "pass" then print("  ok  ${r["name"]}")
    else _printFail(r)
  )

// An Asserter is { "value": Json } — assertion methods take it as first arg via dot-syntax.

export val expect = (value: Json): Json =>
  { "value": value }

export val toBe = (asserter: Json, expected: Json): Assertion =>
  val value = asserter["value"]
  if value == expected then _pass()
  else _fail("expected: ${toString(expected)}\n    actual:   ${toString(value)}")

export val toBeNull = (asserter: Json): Assertion =>
  val value = asserter["value"]
  if value == null then _pass()
  else _fail("expected null, got: ${toString(value)}")

export val toSatisfy = (asserter: Json, pred: Function): Assertion =>
  val value = asserter["value"]
  if pred(value) then _pass()
  else _fail("value did not satisfy predicate: ${toString(value)}")

export val toSucceed = (asserter: Json): Assertion =>
  val value = asserter["value"]
  if value["type"] == "success" then _pass()
  else _fail("expected success, got: ${toString(value)}")

export val toFail = (asserter: Json): Assertion =>
  val value = asserter["value"]
  if value["type"] == "failure" then _pass()
  else _fail("expected failure, got: ${toString(value)}")

export val toFailWith = (asserter: Json, message: String): Assertion =>
  val value = asserter["value"]
  if value["type"] == "failure" && value["error"] == message then _pass()
  else _fail("expected failure with \"${message}\", got: ${toString(value)}")

// A test eagerly runs the body and stores the result alongside the name. The body must return
// an `Assertion[]` (use the `[ expect(...).toBe(...), ... ]` form, even for a single assertion);
// every assertion in the array is evaluated and a test fails if any one of them fails.
export val test = (name: String, body: () => Assertion[]): Json =>
  _evalResult(name, body())

export val suite = (name: String, tests: Json[]): Json =>
  { "name": name, "tests": tests }

export val run = (s: Json): Null =>
  val failed = s["tests"].filter(r => r["type"] == "fail")
  val passCount = length(s["tests"]) - length(failed)
  val failCount = length(failed)
  _printSuiteResults({ "name": s["name"], "results": s["tests"] })
  if failCount == 0 then print("${toString(passCount)} passed")
  else
    print("${toString(failCount)} failed, ${toString(passCount)} passed")
    exit(1)
