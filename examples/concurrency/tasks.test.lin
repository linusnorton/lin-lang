import { expect, toBe, toSatisfy, test, suite, run } from "std/test"
import {
  squareAsync, weightedTriple, firstToFinish, withDeadline,
  retryDivide, safeDivide, nestedValue
} from "./tasks"

val s = suite("concurrency/tasks", [
  test("async/await computes on another thread", () => [
    expect(squareAsync(7)).toBe(49)
  ]),

  test("parallel runs tasks order-preserving", () =>
    val r = weightedTriple(1, 2, 3)
    [
      expect(r[0]).toBe(1),
      expect(r[1]).toBe(4),
      expect(r[2]).toBe(9)
    ]
  ),

  test("race resolves with the first to complete", () => [
    expect(firstToFinish(200, 10)).toBe("fast")
  ]),

  test("timeout abandons the slow thread (-> null)", () => [
    expect(withDeadline(300, 30)).toBe(null)
  ]),

  test("timeout passes the value through when fast enough", () => [
    expect(withDeadline(5, 1000)).toBe("done")
  ]),

  test("retry returns the first non-Error result", () => [
    expect(retryDivide(10, 2, 3)).toBe(5)
  ]),

  test("retry surfaces an Error when every attempt faults", () =>
    val r = retryDivide(10, 0, 3)
    [
      expect(r["type"]).toBe("error")
    ]
  ),

  test("fault isolation: a thunk fault becomes a recoverable value", () => [
    expect(safeDivide(10, 2)).toBe(5),
    expect(safeDivide(10, 0)).toBe(0 - 1)
  ]),

  test("await auto-flattens nested promises", () => [
    expect(nestedValue(42)).toBe(42)
  ]),
])

run(s)
