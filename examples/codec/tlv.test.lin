// Unit suite for tlv.lin — `encode` / `decode` in isolation.
//
// Covers byte-exact wire framing (tag, big-endian 2-byte length, value),
// empty and multi-field messages, and encode/decode round-trips. Object-literal
// field args coerce to Field[] directly.

import { expect, toBe, test, suite, run } from "std/test"
import { encode, decode } from "./tlv"
import { length } from "std/array"

val s = suite("tlv", [
  // --- Byte-exact framing ---
  test("encodes one field as tag, len-hi, len-lo, value", () => [
    expect(encode([{ "tag": 1, "bytes": [65, 66, 67] }])).toBe([1, 0, 3, 65, 66, 67])
  ]),
  test("encodes an empty value as a zero length", () => [
    expect(encode([{ "tag": 9, "bytes": [] }])).toBe([9, 0, 0])
  ]),
  test("the length prefix is two bytes (big-endian), value follows", () =>
    // 3-byte value -> [tag, 0x00, 0x03, ...value]
    val packed = encode([{ "tag": 5, "bytes": [9, 8, 7] }])
    [
      expect(packed[0]).toBe(5),
      expect(packed[1]).toBe(0),
      expect(packed[2]).toBe(3),
      expect(length(packed)).toBe(6)
    ]
  ),
  test("encodes multiple fields back to back", () => [
    // field1 = 1+2+1 = 4 bytes; field2 = 1+2+2 = 5 bytes; total 9
    expect(length(encode([{ "tag": 1, "bytes": [10] }, { "tag": 2, "bytes": [20, 30] }]))).toBe(9)
  ]),

  // --- Round-trips: decode(encode(x)) preserves structure ---
  test("round-trips a single field", () =>
    val back = decode(encode([{ "tag": 7, "bytes": [1, 2, 3, 4] }]))
    [
      expect(length(back)).toBe(1),
      expect(back[0]["tag"]).toBe(7),
      expect(back[0]["bytes"]).toBe([1, 2, 3, 4])
    ]
  ),
  test("round-trips multiple fields preserving order", () =>
    val back = decode(encode([{ "tag": 1, "bytes": [255] }, { "tag": 2, "bytes": [0, 128, 64] }]))
    [
      expect(back[0]["bytes"]).toBe([255]),
      expect(back[1]["tag"]).toBe(2),
      expect(back[1]["bytes"]).toBe([0, 128, 64])
    ]
  ),
  test("round-trips an empty field list", () => [
    expect(decode(encode([]))).toBe([])
  ]),
  test("decodes an empty-valued field back to an empty byte list", () =>
    val back = decode(encode([{ "tag": 3, "bytes": [] }]))
    [
      expect(length(back)).toBe(1),
      expect(back[0]["tag"]).toBe(3),
      expect(back[0]["bytes"]).toBe([])
    ]
  ),
])
run(s)
