import { expect, toBe, test, suite, run } from "std/test"
import { encode, decode } from "./tlv"
import { packNibbles, highNibble, lowNibble, nalType, checksum } from "./bits"
import { length, slice, concat } from "std/array"
import { u32ToBe, u32FromBe } from "std/bytes"
import { toUInt64, toUInt32, toFloat64, toInt32 } from "std/number"

val s = suite("codec", [
  // --- TLV encoding: byte-exact wire format ---
  test("encodes one field as tag,len-hi,len-lo,value", () => [
    expect(encode([{ "tag": 1, "bytes": [65, 66, 67] }])).toBe([1, 0, 3, 65, 66, 67])
  ]),
  test("encodes an empty value as a zero length", () => [
    expect(encode([{ "tag": 9, "bytes": [] }])).toBe([9, 0, 0])
  ]),
  test("encodes multiple fields back to back", () => [
    // field1 = 1+2+1 = 4 bytes; field2 = 1+2+2 = 5 bytes; total 9
    expect(length(encode([{ "tag": 1, "bytes": [10] }, { "tag": 2, "bytes": [20, 30] }]))).toBe(9)
  ]),

  // --- Round-trip: decode(encode(x)) == x ---
  test("round-trips a single field", () =>
    val fields = [{ "tag": 7, "bytes": [1, 2, 3, 4] }]
    val back = decode(encode(fields))
    [
      expect(length(back)).toBe(1),
      expect(back[0]["tag"]).toBe(7),
      expect(back[0]["bytes"]).toBe([1, 2, 3, 4])
    ]
  ),
  test("round-trips multiple fields preserving order", () =>
    val fields = [{ "tag": 1, "bytes": [255] }, { "tag": 2, "bytes": [0, 128, 64] }]
    val back = decode(encode(fields))
    [
      expect(back[0]["bytes"]).toBe([255]),
      expect(back[1]["tag"]).toBe(2),
      expect(back[1]["bytes"]).toBe([0, 128, 64])
    ]
  ),
  test("round-trips an empty field list", () => [
    expect(decode(encode([]))).toBe([])
  ]),

  // --- Bit twiddling (absorbed from the low-level demo) ---
  test("packs and unpacks nibbles", () =>
    val b = packNibbles(0xA, 0x5)
    [
      expect(b).toBe(165),
      expect(highNibble(b)).toBe(10),
      expect(lowNibble(b)).toBe(5)
    ]
  ),
  test("extracts a NAL-type field (low 5 bits)", () => [
    expect(nalType(0x67)).toBe(7)
  ]),
  test("plain bitwise operators", () => [
    expect(0b1100 & 0b1010).toBe(8),
    expect(0b1100 | 0b1010).toBe(14),
    expect(0b1100 ^ 0b1010).toBe(6),
    expect(1 << 4).toBe(16),
    expect(255 >> 4).toBe(15)
  ]),
  test("XOR checksum over a byte list (bitwise on Json projections)", () => [
    expect(checksum([1, 2, 3])).toBe(0),
    expect(checksum([255, 1, 2])).toBe(252)
  ]),

  // --- Integer types + flat-array element typing (absorbed from integer tests) ---
  test("UInt8 flat array holds 0..255 unboxed", () =>
    val buf: UInt8[] = [0x48, 0x49, 0xFF]
    [
      expect(length(buf)).toBe(3),
      expect(buf[2]).toBe(255)
    ]
  ),
  test("Int8 flat array round-trips negatives", () =>
    val signed: Int8[] = [ -1, -128, 127]
    [
      expect(signed[0]).toBe(-1),
      expect(signed[1]).toBe(-128),
      expect(signed[2]).toBe(127)
    ]
  ),
  test("slice preserves the flat element type", () =>
    val buf: UInt8[] = [1, 2, 3, 4, 5]
    [
      expect(buf.slice(1, 4)).toBe([2, 3, 4])
    ]
  ),
  test("concat preserves the flat element type (byte-level reads still work)", () =>
    val a: UInt8[] = [0, 1]
    val b: UInt8[] = [2, 3]
    val joined = a.concat(b)
    [
      expect(length(joined)).toBe(4),
      expect(joined[3]).toBe(3)
    ]
  ),
  test("u32 big-endian round-trip", () =>
    val v = (305419896).toUInt64().toUInt32()
    val bytes = u32ToBe(v)
    [
      expect(length(bytes)).toBe(4),
      expect(u32FromBe(bytes, 0).toFloat64().toInt32()).toBe(305419896)
    ]
  ),

  // --- Churn: many fields encode/decode without flat-array RC corruption (ASan guard) ---
  test("round-trips a large multi-field message", () =>
    val many = [
      { "tag": 1, "bytes": [1] }, { "tag": 2, "bytes": [2, 2] }, { "tag": 3, "bytes": [3, 3, 3] },
      { "tag": 4, "bytes": [4] }, { "tag": 5, "bytes": [5, 5] }, { "tag": 6, "bytes": [6, 6, 6] },
      { "tag": 7, "bytes": [7] }, { "tag": 8, "bytes": [8, 8] }, { "tag": 9, "bytes": [9, 9, 9] }
    ]
    val back = decode(encode(many))
    [
      expect(length(back)).toBe(9),
      expect(back[8]["bytes"]).toBe([9, 9, 9])
    ]
  ),
])
run(s)
