import { suite, test, expect, run, toBe, toBeNull, toSatisfy, toSucceed, toFail, toFailWith } from "std/test"
import { parseInt32, parseFloat64, toInt32, toFloat64, isInt32 } from "std/number"

suite("std/number", [
  test("parseInt32 parses valid decimal strings", () =>
    expect(parseInt32("42")).toBe(42)
    expect(parseInt32("0")).toBe(0)
    expect(parseInt32("-7")).toBe(-7)
    expect(parseInt32("2147483647")).toBe(2147483647)
  ),
  test("parseFloat64 parses float strings", () =>
    expect(parseFloat64("3.14")).toBe(3.14)
    expect(parseFloat64("0.0")).toBe(0.0)
    expect(parseFloat64("-1.5")).toBe(-1.5)
    expect(parseFloat64("1e2")).toBe(100.0)
  ),
  test("parseFloat64 parses integer strings", () =>
    expect(parseFloat64("42")).toBe(42.0)
  ),
  test("toInt32 truncates float to int", () =>
    expect(toInt32(3.9)).toBe(3)
    expect(toInt32(3.1)).toBe(3)
    expect(toInt32(-3.9)).toBe(-3)
    expect(toInt32(0.0)).toBe(0)
  ),
  test("toFloat64 widens int to float", () =>
    expect(toFloat64(42)).toBe(42.0)
    expect(toFloat64(0)).toBe(0.0)
    expect(toFloat64(-5)).toBe(-5.0)
  ),
  test("isInt32 recognises valid integer strings", () =>
    expect(isInt32("42")).toBe(true)
    expect(isInt32("-7")).toBe(true)
    expect(isInt32("0")).toBe(true)
  ),
  test("isInt32 rejects non-integer strings", () =>
    expect(isInt32("3.14")).toBe(false)
    expect(isInt32("hello")).toBe(false)
    expect(isInt32("")).toBe(false)
    expect(isInt32("12abc")).toBe(false)
  ),
  test("dot-syntax for number parsing", () =>
    expect("99".parseInt32()).toBe(99)
    expect("2.5".parseFloat64()).toBe(2.5)
    expect("7".isInt32()).toBe(true)
  )
]).run()
