import { suite, test, expect, run, toBe, toBeNull, toSatisfy, toSucceed, toFail, toFailWith } from "std/test"

val divide = (a: Float64, b: Float64): Json =>
  if b == 0.0 then { "type": "failure", "error": "division by zero" }
  else { "type": "success", "value": a / b }

val safeSqrt = (x: Float64): Json =>
  if x < 0.0 then { "type": "failure", "error": "negative input" }
  else { "type": "success", "value": x }

suite("std/result", [
  test("toSucceed passes on success shape", () =>
    expect(divide(10.0, 2.0)).toSucceed()
    expect(safeSqrt(4.0)).toSucceed()
  ),
  test("toFail passes on failure shape", () =>
    expect(divide(1.0, 0.0)).toFail()
    expect(safeSqrt(-1.0)).toFail()
  ),
  test("toFailWith checks the error message", () =>
    expect(divide(1.0, 0.0)).toFailWith("division by zero")
    expect(safeSqrt(-1.0)).toFailWith("negative input")
  ),
  test("toSucceed fails when given a failure", () =>
    val result = expect(divide(1.0, 0.0)).toSucceed()
    expect(result["type"]).toBe("fail")
  ),
  test("toFail fails when given a success", () =>
    val result = expect(divide(10.0, 2.0)).toFail()
    expect(result["type"]).toBe("fail")
  ),
  test("success value is accessible", () =>
    val r = divide(10.0, 2.0)
    expect(r["type"]).toBe("success")
    expect(r["value"]).toBe(5.0)
  ),
  test("failure error is accessible", () =>
    val r = divide(1.0, 0.0)
    expect(r["type"]).toBe("failure")
    expect(r["error"]).toBe("division by zero")
  ),
  test("toSatisfy can inspect union shapes", () =>
    expect(divide(10.0, 2.0)).toSatisfy(r => r has { "type": "success", value })
    expect(divide(1.0, 0.0)).toSatisfy(r => r has { "type": "failure", error })
  )
]).run()
