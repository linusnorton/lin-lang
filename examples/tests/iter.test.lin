import { suite, test, expect, run, toBe, toBeNull, toSatisfy, toSucceed, toFail, toFailWith } from "std/test"

suite("std/iter", [
  test("range produces integers in [start, end)", () =>
    val result = []
    range(0, 3).for(i => push(result, i))
    expect(result).toBe([0, 1, 2])
  ),
  test("range with non-zero start", () =>
    val result = []
    range(3, 6).for(i => push(result, i))
    expect(result).toBe([3, 4, 5])
  ),
  test("range with equal start and end produces nothing", () =>
    val result = []
    range(5, 5).for(i => push(result, i))
    expect(result).toBe([])
  ),
  test("iterOf iterates over array elements", () =>
    val result = []
    iterOf([10, 20, 30]).for(x => push(result, x))
    expect(result).toBe([10, 20, 30])
  ),
  test("iterOf over empty array produces nothing", () =>
    val result = []
    iterOf([]).for(x => push(result, x))
    expect(result).toBe([])
  ),
  test("range can be used with map via for", () =>
    val result = []
    range(1, 4).for(i => push(result, i * i))
    expect(result).toBe([1, 4, 9])
  )
]).run()
