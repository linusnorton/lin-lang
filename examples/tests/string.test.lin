import { suite, test, expect, run, toBe, toBeNull, toSatisfy, toSucceed, toFail, toFailWith } from "std/test"
import { trim, toUpper, toLower, substring, charAt, indexOf, length, contains,
         startsWith, endsWith, split, join, replace, repeat } from "std/string"

suite("std/string", [
  test("trim removes leading and trailing whitespace", () =>
    expect("  hello  ".trim()).toBe("hello")
    expect("  hello".trim()).toBe("hello")
    expect("hello  ".trim()).toBe("hello")
    expect("hello".trim()).toBe("hello")
    expect("".trim()).toBe("")
  ),
  test("toUpper converts to uppercase", () =>
    expect("hello".toUpper()).toBe("HELLO")
    expect("Hello World".toUpper()).toBe("HELLO WORLD")
    expect("".toUpper()).toBe("")
  ),
  test("toLower converts to lowercase", () =>
    expect("HELLO".toLower()).toBe("hello")
    expect("Hello World".toLower()).toBe("hello world")
    expect("".toLower()).toBe("")
  ),
  test("substring extracts a slice", () =>
    expect("hello".substring(0, 3)).toBe("hel")
    expect("hello".substring(1, 4)).toBe("ell")
    expect("hello".substring(0, 5)).toBe("hello")
    expect("hello".substring(2, 2)).toBe("")
  ),
  test("charAt returns single character", () =>
    expect("hello".charAt(0)).toBe("h")
    expect("hello".charAt(4)).toBe("o")
  ),
  test("indexOf returns first occurrence index", () =>
    expect("hello".indexOf("l")).toBe(2)
    expect("hello".indexOf("hello")).toBe(0)
    expect("hello".indexOf("x")).toBe(-1)
    expect("abcabc".indexOf("b")).toBe(1)
  ),
  test("length returns codepoint count", () =>
    expect("hello".length()).toBe(5)
    expect("".length()).toBe(0)
    expect("hi".length()).toBe(2)
  ),
  test("contains tests for substring", () =>
    expect("hello world".contains("world")).toBe(true)
    expect("hello world".contains("xyz")).toBe(false)
    expect("hello".contains("")).toBe(true)
    expect("hello".contains("hello")).toBe(true)
  ),
  test("startsWith tests prefix", () =>
    expect("hello".startsWith("hel")).toBe(true)
    expect("hello".startsWith("world")).toBe(false)
    expect("hello".startsWith("")).toBe(true)
    expect("hello".startsWith("hello")).toBe(true)
  ),
  test("endsWith tests suffix", () =>
    expect("hello".endsWith("llo")).toBe(true)
    expect("hello".endsWith("world")).toBe(false)
    expect("hello".endsWith("")).toBe(true)
    expect("hello".endsWith("hello")).toBe(true)
  ),
  test("split splits by delimiter", () =>
    expect("a,b,c".split(",")).toBe(["a", "b", "c"])
    expect("hello".split(",")).toBe(["hello"])
    expect("a,,b".split(",")).toBe(["a", "", "b"])
  ),
  test("join joins array with separator", () =>
    expect(["a", "b", "c"].join(",")).toBe("a,b,c")
    expect(["hello"].join(",")).toBe("hello")
    expect(["a", "b"].join(" - ")).toBe("a - b")
    expect([].join(",")).toBe("")
  ),
  test("replace replaces first occurrence", () =>
    expect("hello world".replace("world", "lin")).toBe("hello lin")
    expect("aaa".replace("a", "b")).toBe("baa")
    expect("hello".replace("x", "y")).toBe("hello")
  ),
  test("repeat repeats a string n times", () =>
    expect("ab".repeat(3)).toBe("ababab")
    expect("x".repeat(1)).toBe("x")
    expect("x".repeat(0)).toBe("")
  ),
  test("chaining trim and toUpper", () =>
    expect("  hello  ".trim().toUpper()).toBe("HELLO")
  )
]).run()
