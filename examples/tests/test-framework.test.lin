import { suite, test, expect, run, toBe, toBeNull, toSatisfy, toSucceed, toFail, toFailWith } from "std/test"

// Tests for the test framework itself

val alwaysPass = { "type": "pass" }
val alwaysFail = { "type": "fail", "message": "intentional failure" }

suite("std/test", [
  test("expect.toBe passes on equal values", () =>
    expect(expect(1).toBe(1)["type"]).toBe("pass")
    expect(expect("hello").toBe("hello")["type"]).toBe("pass")
    expect(expect(null).toBe(null)["type"]).toBe("pass")
    expect(expect([1, 2]).toBe([1, 2])["type"]).toBe("pass")
    expect(expect({ "a": 1 }).toBe({ "a": 1 })["type"]).toBe("pass")
  ),
  test("expect.toBe fails on unequal values", () =>
    expect(expect(1).toBe(2)["type"]).toBe("fail")
    expect(expect("a").toBe("b")["type"]).toBe("fail")
    expect(expect([1]).toBe([2])["type"]).toBe("fail")
  ),
  test("expect.toBeNull passes on null", () =>
    expect(expect(null).toBeNull()["type"]).toBe("pass")
  ),
  test("expect.toBeNull fails on non-null", () =>
    expect(expect(0).toBeNull()["type"]).toBe("fail")
    expect(expect("").toBeNull()["type"]).toBe("fail")
  ),
  test("expect.toSatisfy passes when predicate holds", () =>
    expect(expect(5).toSatisfy(x => x > 3)["type"]).toBe("pass")
    expect(expect("hello").toSatisfy(s => length(s) == 5)["type"]).toBe("pass")
  ),
  test("expect.toSatisfy fails when predicate does not hold", () =>
    expect(expect(1).toSatisfy(x => x > 10)["type"]).toBe("fail")
  ),
  test("expect.toSucceed passes on success shape", () =>
    val r = { "type": "success", "value": 42 }
    expect(expect(r).toSucceed()["type"]).toBe("pass")
  ),
  test("expect.toFail passes on failure shape", () =>
    val r = { "type": "failure", "error": "oops" }
    expect(expect(r).toFail()["type"]).toBe("pass")
  ),
  test("expect.toFailWith passes when error matches", () =>
    val r = { "type": "failure", "error": "oops" }
    expect(expect(r).toFailWith("oops")["type"]).toBe("pass")
    expect(expect(r).toFailWith("wrong")["type"]).toBe("fail")
  ),
  test("toBe failure message contains expected and actual", () =>
    val r = expect(1).toBe(2)
    expect(r["type"]).toBe("fail")
    expect(r["message"].contains("expected")).toBe(true)
    expect(r["message"].contains("actual")).toBe(true)
  )
]).run()
