import { suite, test, expect, run, toBe, toBeNull, toSatisfy, toSucceed, toFail, toFailWith } from "std/test"

suite("std/array", [
  test("map transforms each element", () =>
    expect([1, 2, 3].map(x => x * 2)).toBe([2, 4, 6])
    expect([].map(x => x * 2)).toBe([])
    expect(["a", "b"].map(s => s + s)).toBe(["aa", "bb"])
  ),
  test("filter keeps matching elements", () =>
    expect([1, 2, 3, 4].filter(x => x % 2 == 0)).toBe([2, 4])
    expect([1, 2, 3].filter(x => x > 10)).toBe([])
    expect([1, 2, 3].filter(x => x > 0)).toBe([1, 2, 3])
  ),
  test("reduce folds left", () =>
    expect([1, 2, 3, 4].reduce(0, (acc, x) => acc + x)).toBe(10)
    expect([1, 2, 3].reduce(1, (acc, x) => acc * x)).toBe(6)
    expect([].reduce(42, (acc, x) => acc + x)).toBe(42)
  ),
  test("find returns first match or null", () =>
    expect([1, 2, 3].find(x => x > 1)).toBe(2)
    expect([1, 2, 3].find(x => x > 10)).toBeNull()
    expect([].find(x => x > 0)).toBeNull()
  ),
  test("some returns true if any element matches", () =>
    expect([1, 2, 3].some(x => x > 2)).toBe(true)
    expect([1, 2, 3].some(x => x > 10)).toBe(false)
    expect([].some(x => x > 0)).toBe(false)
  ),
  test("every returns true if all elements match", () =>
    expect([2, 4, 6].every(x => x % 2 == 0)).toBe(true)
    expect([1, 2, 3].every(x => x % 2 == 0)).toBe(false)
    expect([].every(x => x > 0)).toBe(true)
  ),
  test("flatMap maps then flattens one level", () =>
    expect([1, 2, 3].flatMap(x => [x, x * 10])).toBe([1, 10, 2, 20, 3, 30])
    expect([].flatMap(x => [x])).toBe([])
    expect([[1, 2], [3]].flatMap(x => x)).toBe([1, 2, 3])
  ),
  test("indexOf returns first index of value or -1", () =>
    expect([1, 2, 3].indexOf(2)).toBe(1)
    expect([1, 2, 3].indexOf(4)).toBe(-1)
    expect([1, 2, 1].indexOf(1)).toBe(0)
    expect([].indexOf(1)).toBe(-1)
  ),
  test("reverse returns a reversed copy", () =>
    expect([1, 2, 3].reverse()).toBe([3, 2, 1])
    expect([1].reverse()).toBe([1])
    expect([].reverse()).toBe([])
  ),
  test("chaining map and filter", () =>
    val result = [1, 2, 3, 4, 5]
      .map(x => x * x)
      .filter(x => x > 5)
    expect(result).toBe([9, 16, 25])
  )
]).run()
