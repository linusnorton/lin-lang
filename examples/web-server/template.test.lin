import { expect, toBe, test, suite, run } from "std/test"
import { render } from "std/template"
import { contains } from "std/string"

// Templating coverage (absorbed from the standalone template demo): render the
// server's HTML view and assert the ${...} holes are filled from the data object.
val s = suite("template", [
  test("renders index.lint filling all holes", () =>
    val out = render("examples/web-server/views/index.lint", {
      "title": "T", "heading": "H", "status": "ok", "version": "1.0"
    })
    [
      expect(out.contains("<title>T</title>")).toBe(true),
      expect(out.contains("<h1>H</h1>")).toBe(true),
      expect(out.contains("Status: ok")).toBe(true),
      expect(out.contains("Version: 1.0")).toBe(true)
    ]
  ),
  test("leaves no unfilled ${ } holes", () =>
    val out = render("examples/web-server/views/index.lint", {
      "title": "T", "heading": "H", "status": "ok", "version": "1.0"
    })
    [
      expect(out.contains("\${")).toBe(false)
    ]
  ),
])
run(s)
