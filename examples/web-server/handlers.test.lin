import { expect, toBe, test, suite, run } from "std/test"
import { handleStatus, handleUser } from "./handlers"

val makeReq = (method: String, path: String): Json =>
  { "method": method, "path": path, "query": "", "headers": {}, "body": "" }

val s = suite("handlers", [
  test("handleStatus returns 200", () =>
    val resp = handleStatus(makeReq("GET", "/api/status"))
    val checks = [
      expect(resp["status"]).toBe(200)
    ]
    checks
  ),
  test("handleUser returns 200 for valid path", () =>
    val resp = handleUser(makeReq("GET", "/users/42"))
    val checks = [
      expect(resp["status"]).toBe(200)
    ]
    checks
  ),
  test("handleUser returns 404 for non-matching path", () =>
    val resp = handleUser(makeReq("GET", "/other"))
    val checks = [
      expect(resp["status"]).toBe(404)
    ]
    checks
  ),
])
run(s)
