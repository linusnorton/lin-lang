import { expect, toBe, test, suite, run } from "std/test"
import { validateForm } from "./form"
import { isOk } from "./result"

// End-to-end: the full form-validation pipeline (validate.lin validators composed via
// result.lin combinators in form.lin), asserting both the happy path and that the
// FIRST failing field short-circuits the chain.
val s = suite("result integration", [
  test("a fully valid form decodes to a Registration", () =>
    val r = validateForm({ "name": "Ada", "email": "ada@example.com", "age": "36" })
    [
      expect(isOk(r)).toBe(true),
      expect(r["value"]["name"]).toBe("Ada"),
      expect(r["value"]["email"]).toBe("ada@example.com"),
      expect(r["value"]["age"]).toBe(36)
    ]
  ),
  test("an empty name fails first (before email/age)", () => [
    expect(validateForm({ "name": "", "email": "bad", "age": "999" })["error"]).toBe("name must not be empty")
  ]),
  test("a valid name but bad email fails at email", () => [
    expect(validateForm({ "name": "Bo", "email": "nope", "age": "999" })["error"]).toBe("invalid email: nope")
  ]),
  test("name+email valid but bad age fails at age", () => [
    expect(isOk(validateForm({ "name": "Cleo", "email": "c@x.io", "age": "999" }))).toBe(false)
  ]),
])
run(s)
