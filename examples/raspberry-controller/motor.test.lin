import { suite, test, expect, run, toBe } from "std/test"
import { motorCommand, PWM_PERIOD } from "./motor"

// Ports the pure-logic intent of Motor::set() from server/src/motor.rs (the Rust
// tests there exercise the GPIO side, which we cannot; these assert the speed→PWM
// mapping that drives it). Test bodies are Assertion[] arrays so every assertion
// runs. PWM_PERIOD is 1000, so duty = round(|speed| * 1000).

val s = suite("raspberry-motor", [
  test("forward speed drives rpwm with proportional duty", () => [
    expect(motorCommand(1.0)["channel"]).toBe("rpwm"),
    expect(motorCommand(1.0)["duty"]).toBe(1000),
    expect(motorCommand(0.5)["channel"]).toBe("rpwm"),
    expect(motorCommand(0.5)["duty"]).toBe(500),
    expect(motorCommand(0.25)["duty"]).toBe(250)
  ]),

  test("reverse speed drives lpwm with proportional duty", () => [
    expect(motorCommand(0.0 - 1.0)["channel"]).toBe("lpwm"),
    expect(motorCommand(0.0 - 1.0)["duty"]).toBe(1000),
    expect(motorCommand(0.0 - 0.5)["channel"]).toBe("lpwm"),
    expect(motorCommand(0.0 - 0.5)["duty"]).toBe(500)
  ]),

  test("zero speed stops both pins (duty 0)", () => [
    expect(motorCommand(0.0)["channel"]).toBe("stop"),
    expect(motorCommand(0.0)["duty"]).toBe(0)
  ]),

  test("out-of-range speed is clamped before mapping", () => [
    expect(motorCommand(5.0)["channel"]).toBe("rpwm"),
    expect(motorCommand(5.0)["duty"]).toBe(1000),
    expect(motorCommand(0.0 - 3.0)["channel"]).toBe("lpwm"),
    expect(motorCommand(0.0 - 3.0)["duty"]).toBe(1000)
  ]),

  test("PWM_PERIOD is 1000us (1 kHz)", () => [
    expect(PWM_PERIOD).toBe(1000.0)
  ]),
])

run(s)
