import { expect, toBe, test, suite, run } from "std/test"

// `classify` has a two-way branch; the test below only ever takes the
// then-branch, so the else-branch line should report a zero hit count.
val classify = (n: Int32) =>
  if n > 0 then
    "positive"
  else
    "non-positive"

val s = suite("cov_demo", [
  test("classify positive", () =>
    expect(classify(5)).toBe("positive")
  ),
])

run(s)
