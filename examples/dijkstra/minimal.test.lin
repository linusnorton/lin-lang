import { expect, toBe, test, suite, run } from "std/test"
import { dijkstra } from "./algorithm"
import { buildAdj } from "./graph"

val s = suite("minimal", [
  test("dist to self is 0", () =>
    val adj = buildAdj([{ "from": "A", "to": "B", "weight": 5 }])
    val result = dijkstra(adj, "A", ["A", "B"])
    [
      expect(result["dist"]["A"]).toBe(0)
    ]
  ),
])
run(s)
