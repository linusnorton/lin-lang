import { expect, toBe, test, suite, run } from "std/test"
import { dijkstra } from "./algorithm"
import { buildAdj, reconstructPath } from "./graph"
import { join } from "std/string"

// End-to-end over the full graph topology (the same edges as graph.json): run
// Dijkstra from A across all nodes, then assert the shortest distance to E AND the
// reconstructed path. Best route is A -> C -> B -> D -> E = 3 + 4 + 2 + 5 = 14.
val nodes = ["A", "B", "C", "D", "E"]
val edges = [
  { "from": "A", "to": "B", "weight": 10 },
  { "from": "A", "to": "C", "weight": 3 },
  { "from": "C", "to": "B", "weight": 4 },
  { "from": "C", "to": "D", "weight": 8 },
  { "from": "B", "to": "D", "weight": 2 },
  { "from": "D", "to": "E", "weight": 5 },
  { "from": "B", "to": "E", "weight": 11 }
]

val s = suite("dijkstra end-to-end", [
  test("shortest distances from A across the whole graph", () =>
    val result = dijkstra(buildAdj(edges), "A", nodes)
    val dist = result["dist"]
    [
      expect(dist["A"]).toBe(0),
      expect(dist["C"]).toBe(3),
      expect(dist["B"]).toBe(7),
      expect(dist["D"]).toBe(9),
      expect(dist["E"]).toBe(14)
    ]
  ),
  test("reconstructs the optimal A -> E path", () =>
    val result = dijkstra(buildAdj(edges), "A", nodes)
    val path = reconstructPath(result["prev"], "A", "E")
    [
      expect(path.join(" ")).toBe("A C B D E")
    ]
  ),
])
run(s)
