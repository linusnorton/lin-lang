// Unit suite for eval.lin — `evalAst` over AST fixtures, in isolation.
//
// AST fixtures are built directly (not via lexer/parser) so this tests the
// evaluator alone: arithmetic, precedence already encoded in the tree, nested
// trees, propagation of an incoming parse failure, and div-by-zero as a
// recoverable failure (not a trap).

import { expect, toBe, toSucceed, toFailWith, test, suite, run } from "std/test"
import { evalAst } from "./eval"

// AST + result builders. evalAst takes the parser's tagged result
// ({ "type": "success", "value": <ast> } | failure) as dynamic Json, so the
// fixtures are Json builders mirroring the parser's node/result shapes.
val numNode = (v: Int32): Json => { "kind": "num", "value": v }
val binop = (o: String, l: Json, r: Json): Json => { "kind": "binop", "op": o, "left": l, "right": r }
val ok = (ast: Json): Json => { "type": "success", "value": ast }
val parseFail = (msg: String): Json => { "type": "failure", "error": msg }

// Convenience: the Int32 of a successful eval (sentinel on failure).
val valueOf = (parsed: Json): Int32 =>
  match evalAst(parsed)
    has { "type": "success", value } => value
    else => -999999

val s = suite("eval", [
  // --- Leaves and the four operators ---
  test("evaluates a bare number", () => [
    expect(valueOf(ok(numNode(42)))).toBe(42)
  ]),
  test("evaluates addition", () => [
    expect(valueOf(ok(binop("+", numNode(2), numNode(3))))).toBe(5)
  ]),
  test("evaluates subtraction", () => [
    expect(valueOf(ok(binop("-", numNode(10), numNode(4))))).toBe(6)
  ]),
  test("evaluates multiplication", () => [
    expect(valueOf(ok(binop("*", numNode(6), numNode(7))))).toBe(42)
  ]),
  test("evaluates integer division", () => [
    expect(valueOf(ok(binop("/", numNode(20), numNode(4))))).toBe(5)
  ]),

  // --- Nested trees (precedence already baked into the AST) ---
  test("evaluates 2 + 3 * 4 (mul subtree on the right)", () => [
    expect(valueOf(ok(binop("+", numNode(2), binop("*", numNode(3), numNode(4)))))).toBe(14)
  ]),
  test("evaluates a deep left-associative chain", () => [
    // ((100 / 5) / 2) = 10
    expect(valueOf(ok(binop("/", binop("/", numNode(100), numNode(5)), numNode(2))))).toBe(10)
  ]),

  // --- Recoverable failures ---
  test("division by zero is a recoverable failure", () => [
    expect(evalAst(ok(binop("/", numNode(7), numNode(0))))).toFailWith("division by zero")
  ]),
  test("nested division by zero propagates", () => [
    expect(evalAst(ok(binop("+", numNode(1), binop("/", numNode(6), numNode(0)))))).toFailWith("division by zero")
  ]),
  test("an incoming parse failure passes straight through", () => [
    expect(evalAst(parseFail("expected number"))).toFailWith("expected number")
  ]),
])
run(s)
