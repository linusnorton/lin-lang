// Evaluator for the calc AST.
//
// Walks the tree produced by the parser, computing an Int32 result. Division by
// zero is reported as a recoverable failure value (not a trap), so the whole
// `evaluate` pipeline returns a tagged result the caller pattern-matches on.

import { parseInt32 } from "std/number"

// Tagged-result shapes. The discriminant field `type` is typed String (spec:
// string literals have base type String, not a singleton type).
type Failure = { "type": String, "error": String }
type EvalSuccess = { "type": String, "value": Int32 }
type Evaluated = EvalSuccess | Failure

val fail = (msg: String): Failure =>
  { "type": "failure", "error": msg }

val isFailure = (x: Json): Boolean =>
  x["type"] == "failure"

// Evaluate one AST node to either a number wrapped in success, or a failure.
// `node` walks a recursive AST union ({kind:"num",value} | {kind:"binop",...})
// indexed by per-variant fields after a `kind` test, so it stays dynamic Json;
// likewise the recursive sub-results are read via `["value"]` after isFailure.
val evalNode = (node: Json): Json =>
  if node["kind"] == "num" then
    { "type": "success", "value": node["value"] }
  else
    val left = evalNode(node["left"])
    if isFailure(left) then left
    else
      val right = evalNode(node["right"])
      if isFailure(right) then right
      else
        val a = left["value"]
        val b = right["value"]
        val op = node["op"]
        if op == "+" then { "type": "success", "value": a + b }
        else if op == "-" then { "type": "success", "value": a - b }
        else if op == "*" then { "type": "success", "value": a * b }
        else if b == 0 then fail("division by zero")
        else { "type": "success", "value": a / b }

// Public entry: an AST result (success/failure from the parser) -> evaluated result.
export val evalAst = (parsed: Json): Evaluated =>
  if isFailure(parsed) then parsed
  else evalNode(parsed["value"])
