import { expect, toBe, toSatisfy, test, suite, run } from "std/test"
import { spawn, readStdout, wait } from "std/process"
import { length } from "std/array"

// Drive a real subprocess and assert on the recoverable, deterministic parts: the
// bytes it wrote to stdout and its exit code. (The Rust integration suite holds the
// lower-level spawn/exit-code assertions; this is the Lin-level smoke coverage.)
val s = suite("processes", [
  test("reads a subprocess's stdout bytes", () =>
    val h = spawn("sh", ["-c", "printf 'Hi'"])
    val buf: UInt8[] = [0, 0, 0, 0]
    val n = readStdout(h, buf)
    val code = wait(h)
    [
      expect(n).toBe(2),
      expect(buf[0]).toBe(72),   // 'H'
      expect(buf[1]).toBe(105),  // 'i'
      expect(code).toBe(0)
    ]
  ),
  test("propagates a non-zero exit code", () =>
    val h = spawn("sh", ["-c", "exit 3"])
    val code = wait(h)
    [
      expect(code).toBe(3)
    ]
  ),
])
run(s)
